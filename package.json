{
  "name": "@drguptavivek/who-2022-va",
  "version": "0.1.0",
  "type": "module",
  "description": "Independent JavaScript implementation of the 2022 WHO verbal autopsy instrument.",
  "license": "MIT",
  "author": "Vivek Gupta",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/drguptavivek/WHO-va-2022.git"
  },
  "homepage": "https://github.com/drguptavivek/WHO-va-2022#readme",
  "bugs": {
    "url": "https://github.com/drguptavivek/WHO-va-2022/issues"
  },
  "keywords": [
    "verbal-autopsy",
    "epidemiology",
    "public-health",
    "react",
    "react-native",
    "web-component"
  ],
  "files": [
    "dist",
    "LICENSE",
    "NOTICE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./native": {
      "types": "./dist/native.d.ts",
      "react-native": "./dist/native.js",
      "import": "./dist/native.js"
    },
    "./web": {
      "types": "./dist/web.d.ts",
      "browser": "./dist/web.js",
      "import": "./dist/web.js"
    },
    "./web-component": {
      "types": "./dist/web-component.d.ts",
      "browser": "./dist/web-component.js",
      "import": "./dist/web-component.js"
    }
  },
  "scripts": {
    "dev": "vite demo --host 127.0.0.1",
    "build:demo": "vite build demo",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:headed": "E2E_SLOW_MO=${E2E_SLOW_MO:-800} playwright test --headed --workers=1",
    "test:e2e:report": "playwright show-report",
    "lint": "eslint src tests scripts demo *.config.ts --max-warnings=0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "build": "tsup",
    "check": "pnpm lint && pnpm format:check && pnpm typecheck && pnpm test && pnpm build",
    "check:all": "pnpm check && pnpm test:e2e",
    "prepublishOnly": "pnpm check"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18",
    "react-native": ">=0.73",
    "react-native-svg": ">=15",
    "react-native-web": ">=0.19"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    },
    "react-native": {
      "optional": true
    },
    "react-native-svg": {
      "optional": true
    },
    "react-native-web": {
      "optional": true
    }
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@types/node": "^24.0.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@types/react-native-web": "0.19.2",
    "eslint": "^10.7.0",
    "eslint-plugin-import-x": "^4.17.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.9.5",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-native": "^0.86.0",
    "react-native-svg": "15.15.4",
    "react-native-web": "^0.21.2",
    "tsup": "^8.5.1",
    "tsx": "^4.20.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.64.0",
    "vite": "^8.1.5",
    "vitest": "^4.1.10"
  },
  "packageManager": "pnpm@11.9.0"
}
